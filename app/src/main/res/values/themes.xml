<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MyApplication" parent="Theme.Material3.DayNight">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="android:windowBackground">@color/fitness_bg_navy</item>
        <item name="android:textColorPrimary">@color/fitness_text_primary</item>
        <item name="android:textColorSecondary">@color/fitness_text_secondary</item>
        <item name="colorPrimary">@color/fitness_primary_orange</item>
    </style>

    <style name="Theme.MyApplication" parent="Base.Theme.MyApplication" />

    <!-- Shared Custom UI Styles -->
    <style name="Widget.Fitness.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">@dimen/spacing_medium</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <style name="Widget.Fitness.Button.Secondary" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="android:textColor">@color/fitness_text_primary</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">@dimen/spacing_medium</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <style name="Widget.Fitness.EditText" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/bg_input_field</item>
        <item name="android:padding">@dimen/spacing_medium</item>
        <item name="android:textColor">@color/fitness_text_primary</item>
        <item name="android:textColorHint">@color/fitness_text_secondary</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <style name="Widget.Fitness.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="android:background">@drawable/bg_rounded_card</item>
    </style>
</resources>