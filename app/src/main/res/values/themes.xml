<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MyApplication" parent="Theme.Material3.Dark">
        <item name="android:windowBackground">@color/fitness_bg_navy</item>
        <item name="android:textColorPrimary">@color/fitness_text_primary</item>
        <item name="android:textColorSecondary">@color/fitness_text_secondary</item>
        <item name="colorPrimary">@color/fitness_primary_orange</item>

        <!-- Seamless Action Bar -->
        <item name="actionBarStyle">@style/Widget.Fitness.ActionBar</item>
        <item name="windowActionBarOverlay">false</item>
        <item name="android:statusBarColor">@color/fitness_bg_navy</item>
    </style>

    <style name="Widget.Fitness.ActionBar" parent="Widget.Material3.ActionBar.Solid">
        <item name="background">@color/fitness_bg_navy</item>
        <item name="elevation">0dp</item>
        <item name="titleTextColor">@color/fitness_text_primary</item>
    </style>

    <style name="Theme.MyApplication" parent="Base.Theme.MyApplication" />

    <!-- Shared Custom UI Styles -->
    <style name="Widget.Fitness.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">@dimen/spacing_medium</item>
        <item name="android:minHeight">@dimen/control_height</item>
    </style>

    <style name="Widget.Fitness.Button.Secondary" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="android:textColor">@color/fitness_text_primary</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">@dimen/spacing_medium</item>
        <item name="android:minHeight">@dimen/control_height</item>
    </style>

    <style name="Widget.Fitness.EditText" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/bg_input_field</item>
        <item name="android:padding">@dimen/spacing_medium</item>
        <item name="android:textColor">@color/fitness_text_primary</item>
        <item name="android:textColorHint">@color/fitness_text_secondary</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:minHeight">@dimen/control_height</item>
    </style>

    <style name="Widget.Fitness.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="android:background">@drawable/bg_rounded_card</item>
    </style>

    <style name="WidgetFitnessSpinner">
        <item name="android:layout_height">@dimen/control_height</item>
        <item name="android:background">@drawable/bg_input_field</item>
        <item name="android:padding">@dimen/spacing_small</item>
        <item name="android:popupBackground">@color/fitness_surface_navy</item>
    </style>

    <style name="TextAppearanceFitnessScreenTitle">
        <item name="android:textColor">@color/fitness_text_primary</item>
        <item name="android:textSize">@dimen/text_size_h1</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearanceFitnessScreenSubtitle">
        <item name="android:textColor">@color/fitness_text_secondary</item>
        <item name="android:textSize">@dimen/text_size_body</item>
    </style>

    <style name="TextAppearanceFitnessCardTitle">
        <item name="android:textColor">@color/fitness_text_primary</item>
        <item name="android:textSize">@dimen/text_size_h2</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearanceFitnessSectionLabel">
        <item name="android:textColor">@color/fitness_text_secondary</item>
        <item name="android:textSize">@dimen/text_size_caption</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearanceFitnessBody">
        <item name="android:textColor">@color/fitness_text_primary</item>
        <item name="android:textSize">@dimen/text_size_body</item>
    </style>

    <style name="TextAppearanceFitnessCaption">
        <item name="android:textColor">@color/fitness_text_secondary</item>
        <item name="android:textSize">@dimen/text_size_caption</item>
    </style>
</resources>
