<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MyApplication" parent="Theme.Material3.Dark">
        <item name="android:windowBackground">@color/fitness_bg_navy</item>
        <item name="android:textColorPrimary">@color/fitness_text_primary</item>
        <item name="android:textColorSecondary">@color/fitness_text_secondary</item>
        <item name="colorPrimary">@color/fitness_primary_orange</item>

        <!-- Seamless Action Bar -->
        <item name="actionBarStyle">@style/Widget.Fitness.ActionBar</item>
        <item name="windowActionBarOverlay">false</item>
        <item name="android:statusBarColor">@color/fitness_bg_navy</item>
    </style>
</resources>