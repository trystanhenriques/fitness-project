<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitness_bg_navy"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding">

    <TextView
        style="@style/TextAppearanceFitnessScreenTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/header_top_spacing"
        android:text="Workout History" />

    <TextView
        style="@style/TextAppearanceFitnessScreenSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_small"
        android:layout_marginBottom="@dimen/spacing_large"
        android:text="See every session in one clean timeline." />

    <TextView
        style="@style/TextAppearanceFitnessCardEyebrow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Session Timeline" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_small"
        android:layout_weight="1">

        <ListView
            android:id="@+id/listHistory"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@android:color/transparent"
            android:dividerHeight="@dimen/list_divider_height"
            android:listSelector="@android:color/transparent" />

        <LinearLayout
            android:id="@+id/emptyHistoryState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_subtle_panel"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="@dimen/card_padding_large"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="@dimen/hero_icon_size"
                android:layout_height="@dimen/hero_icon_size"
                android:background="@drawable/bg_icon_container_orange">

                <ImageView
                    android:layout_width="@dimen/inline_icon_size"
                    android:layout_height="@dimen/inline_icon_size"
                    android:layout_gravity="center"
                    android:contentDescription="No workout history"
                    android:src="@android:drawable/ic_menu_agenda"
                    android:tint="@color/fitness_text_primary" />
            </FrameLayout>

            <TextView
                android:id="@+id/txtHistoryEmptyTitle"
                style="@style/TextAppearanceFitnessEmptyTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_medium"
                android:gravity="center"
                android:text="No workouts logged" />

            <TextView
                android:id="@+id/txtHistoryEmptyMessage"
                style="@style/TextAppearanceFitnessCaption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:gravity="center"
                android:text="Start a workout and your training history will appear here."
                android:textColor="@color/fitness_text_secondary" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
