<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="@dimen/spacing_large"
    android:paddingBottom="@dimen/list_group_gap">

    <FrameLayout
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginEnd="@dimen/spacing_small"
        android:background="@drawable/bg_icon_container_blue">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="center"
            android:contentDescription="Workout date"
            android:src="@android:drawable/ic_menu_today"
            android:tint="@color/fitness_text_primary" />
    </FrameLayout>

    <TextView
        android:id="@+id/txtGroupHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/fitness_text_primary"
        android:textSize="@dimen/text_size_body"
        android:textStyle="bold" />
</LinearLayout>
