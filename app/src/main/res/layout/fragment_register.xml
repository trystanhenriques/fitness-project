<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding"
        android:gravity="center_vertical"
        android:background="@color/fitness_bg_navy">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textColor="@color/fitness_text_primary"
            android:textSize="@dimen/text_size_h1"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_small" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Join to start tracking your workouts"
            android:textColor="@color/fitness_text_secondary"
            android:textSize="@dimen/text_size_body"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_xlarge" />

        <TextView
            android:id="@+id/textError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/fitness_error"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_medium"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_rounded_card"
            android:orientation="vertical"
            android:padding="@dimen/spacing_large"
            android:layout_marginBottom="@dimen/spacing_xlarge">

            <EditText
                android:id="@+id/editUsername"
                style="@style/Widget.Fitness.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Choose a Username"
                android:inputType="textNoSuggestions"
                android:layout_marginBottom="@dimen/spacing_medium" />

            <EditText
                android:id="@+id/editPassword"
                style="@style/Widget.Fitness.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Create a Password"
                android:inputType="textPassword"
                android:layout_marginBottom="@dimen/spacing_medium" />

            <EditText
                android:id="@+id/editConfirmPassword"
                style="@style/Widget.Fitness.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Confirm Password"
                android:inputType="textPassword" />
        </LinearLayout>

        <Button
            android:id="@+id/btnRegister"
            style="@style/Widget.Fitness.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:layout_marginBottom="@dimen/spacing_medium" />

        <Button
            android:id="@+id/btnBackToLogin"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Already have an account? Log In"
            android:textColor="@color/fitness_text_secondary"
            android:textSize="@dimen/text_size_body"
            android:minHeight="56dp"
            android:layout_marginTop="@dimen/spacing_small" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/spacing_medium"
            android:indeterminateTint="@color/fitness_primary_orange"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
