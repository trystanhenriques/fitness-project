<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitness_bg_navy"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_large"
        android:text="Form Check"
        android:textColor="@color/fitness_text_primary"
        android:textSize="@dimen/text_size_h1"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_small"
        android:layout_marginBottom="@dimen/spacing_xlarge"
        android:text="Ensure your technique is solid"
        android:textColor="@color/fitness_text_secondary"
        android:textSize="@dimen/text_size_body" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_rounded_card"
        android:orientation="vertical"
        android:padding="@dimen/spacing_large"
        android:layout_marginBottom="@dimen/spacing_xlarge">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Exercise"
            android:textColor="@color/fitness_text_secondary"
            android:textSize="@dimen/text_size_caption"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerExercise"
            android:layout_width="match_parent"
            android:layout_height="56dp" android:popupBackground="@color/fitness_surface_navy"
            android:layout_marginTop="@dimen/spacing_small"
            android:background="@drawable/bg_input_field"
            android:padding="@dimen/spacing_small" />
    </LinearLayout>

    <Button
        android:id="@+id/btnContinue"
        style="@style/Widget.Fitness.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Continue" />

</LinearLayout>