<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Workout Tracker"
        android:textSize="26sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnStartNewWorkout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Start New Workout"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btnViewProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="View My Progress"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btnWorkoutHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Workout History"
        android:textSize="18sp" />

</LinearLayout>