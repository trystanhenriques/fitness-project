<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitness_bg_navy"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <TextView
            style="@style/TextAppearanceFitnessScreenSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_large"
            android:layout_marginBottom="@dimen/spacing_xlarge"
            android:text="Create a weekly training split around your current goal and available days." />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xlarge"
            android:background="@drawable/bg_rounded_card"
            android:orientation="vertical"
            android:padding="@dimen/spacing_large">

            <TextView
                style="@style/TextAppearanceFitnessSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select Goal" />

            <Spinner
                android:id="@+id/spinnerGoal"
                style="@style/WidgetFitnessSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small" />

            <TextView
                style="@style/TextAppearanceFitnessSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_large"
                android:text="Describe Your Specific Goals (Optional)" />

            <EditText
                android:id="@+id/etSpecificGoals"
                style="@style/Widget.Fitness.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:gravity="top|start"
                android:hint="e.g. Prepare for a 5k, build bench strength..."
                android:inputType="textMultiLine"
                android:minHeight="@dimen/text_area_height" />

            <TextView
                style="@style/TextAppearanceFitnessSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_large"
                android:text="Days per Week" />

            <RadioGroup
                android:id="@+id/rgDays"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rb2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="2"
                        android:textColor="@color/fitness_text_primary" />

                    <RadioButton
                        android:id="@+id/rb3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:checked="true"
                        android:text="3"
                        android:textColor="@color/fitness_text_primary" />

                    <RadioButton
                        android:id="@+id/rb4"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="4"
                        android:textColor="@color/fitness_text_primary" />

                    <RadioButton
                        android:id="@+id/rb5"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="5"
                        android:textColor="@color/fitness_text_primary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rb6"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="6"
                        android:textColor="@color/fitness_text_primary" />

                    <RadioButton
                        android:id="@+id/rb7"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="7"
                        android:textColor="@color/fitness_text_primary" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="2" />
                </LinearLayout>
            </RadioGroup>
        </LinearLayout>

        <Button
            android:id="@+id/btnGeneratePlan"
            style="@style/Widget.Fitness.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Generate Weekly Plan" />

        <TextView
            android:id="@+id/txtWeeklyPlan"
            style="@style/TextAppearanceFitnessCaption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_large"
            android:textColor="@color/fitness_text_secondary"
            android:textIsSelectable="true" />

    </LinearLayout>
</ScrollView>
