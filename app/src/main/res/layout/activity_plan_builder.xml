<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitness_bg_navy"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <TextView
            style="@style/TextAppearanceFitnessScreenTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/header_top_spacing"
            android:text="Build Your Week" />

        <TextView
            style="@style/TextAppearanceFitnessScreenSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_small"
            android:layout_marginBottom="@dimen/spacing_large"
            android:text="Build a clean weekly split around your goal and schedule." />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_large"
            android:background="@drawable/bg_subtle_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/card_padding_large">

            <FrameLayout
                android:layout_width="@dimen/hero_icon_size"
                android:layout_height="@dimen/hero_icon_size"
                android:layout_marginEnd="@dimen/spacing_medium"
                android:background="@drawable/bg_icon_container_yellow">

                <ImageView
                    android:layout_width="@dimen/inline_icon_size"
                    android:layout_height="@dimen/inline_icon_size"
                    android:layout_gravity="center"
                    android:contentDescription="Weekly planner"
                    android:src="@android:drawable/ic_menu_agenda"
                    android:tint="@color/fitness_text_primary" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/TextAppearanceFitnessCardEyebrow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Weekly Structure" />

                <TextView
                    style="@style/TextAppearanceFitnessBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xsmall"
                    android:text="Choose a goal, add optional focus notes, and generate a structured weekly plan."
                    android:textColor="@color/fitness_text_tertiary" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_large"
            android:background="@drawable/bg_rounded_card"
            android:orientation="vertical"
            android:padding="@dimen/card_padding_large">

            <TextView
                style="@style/TextAppearanceFitnessCardEyebrow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Plan Inputs" />

            <TextView
                style="@style/TextAppearanceFitnessCardTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xsmall"
                android:text="Set up your training week" />

            <TextView
                style="@style/TextAppearanceFitnessSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_large"
                android:text="Select Goal" />

            <Spinner
                android:id="@+id/spinnerGoal"
                style="@style/WidgetFitnessSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small" />

            <TextView
                style="@style/TextAppearanceFitnessSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_large"
                android:text="Specific Focus Notes (Optional)" />

            <EditText
                android:id="@+id/etSpecificGoals"
                style="@style/Widget.Fitness.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:gravity="top|start"
                android:hint="e.g. extra chest work, build bench strength, prep for a 5k"
                android:inputType="textMultiLine"
                android:minHeight="@dimen/text_area_height" />

            <TextView
                style="@style/TextAppearanceFitnessSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_large"
                android:text="Days per Week" />

            <RadioGroup
                android:id="@+id/rgDays"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rb2"
                        style="@style/WidgetFitnessSelectionControl"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="2" />

                    <RadioButton
                        android:id="@+id/rb3"
                        style="@style/WidgetFitnessSelectionControl"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:checked="true"
                        android:text="3" />

                    <RadioButton
                        android:id="@+id/rb4"
                        style="@style/WidgetFitnessSelectionControl"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="4" />

                    <RadioButton
                        android:id="@+id/rb5"
                        style="@style/WidgetFitnessSelectionControl"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="5" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rb6"
                        style="@style/WidgetFitnessSelectionControl"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="6" />

                    <RadioButton
                        android:id="@+id/rb7"
                        style="@style/WidgetFitnessSelectionControl"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="7" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="2" />
                </LinearLayout>
            </RadioGroup>
        </LinearLayout>

        <Button
            android:id="@+id/btnGeneratePlan"
            style="@style/Widget.Fitness.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_medium"
            android:text="Generate Weekly Plan" />

        <TextView
            android:id="@+id/txtWeeklyPlan"
            style="@style/TextAppearanceFitnessCaption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_large"
            android:textColor="@color/fitness_text_secondary"
            android:textIsSelectable="true"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
