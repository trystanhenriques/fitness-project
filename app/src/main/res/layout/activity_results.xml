<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitness_bg_navy"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <TextView
            android:id="@+id/txtResultsTitle"
            style="@style/TextAppearanceFitnessScreenTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_large"
            android:text="Feedback" />

        <TextView
            android:id="@+id/txtCues"
            style="@style/TextAppearanceFitnessScreenSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_small"
            android:layout_marginBottom="@dimen/spacing_medium" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_large"
            android:background="@drawable/bg_rounded_card"
            android:orientation="vertical"
            android:padding="@dimen/spacing_large">

            <TextView
                style="@style/TextAppearanceFitnessCardTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Your Experience Tier" />

            <TextView
                android:id="@+id/txtTierName"
                style="@style/TextAppearanceFitnessBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:text="Beginner"
                android:textColor="@color/fitness_primary_orange"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progressTier"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_medium"
                android:max="20"
                android:progress="0"
                android:progressBackgroundTint="@color/fitness_input_bg"
                android:progressTint="@color/fitness_primary_orange" />

            <TextView
                android:id="@+id/txtTierProgress"
                style="@style/TextAppearanceFitnessCaption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:text="5 workouts until Intermediate" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_rounded_card"
            android:orientation="vertical"
            android:padding="@dimen/spacing_large">

            <TextView
                style="@style/TextAppearanceFitnessCardTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Next Steps" />

            <TextView
                android:id="@+id/txtNextSteps"
                style="@style/TextAppearanceFitnessBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small" />
        </LinearLayout>

        <TextView
            style="@style/TextAppearanceFitnessCaption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xlarge"
            android:gravity="center"
            android:text="Not medical advice. Stop if you feel sharp or worsening pain."
            android:textColor="@color/fitness_error" />

        <Button
            android:id="@+id/btnAnotherExercise"
            style="@style/Widget.Fitness.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xlarge"
            android:text="Check Another Exercise" />

        <Button
            android:id="@+id/btnBackToMain"
            style="@style/Widget.Fitness.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_medium"
            android:layout_marginBottom="@dimen/spacing_xlarge"
            android:text="Back to Dashboard" />

    </LinearLayout>
</ScrollView>
