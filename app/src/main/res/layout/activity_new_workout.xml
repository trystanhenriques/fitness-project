<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitness_bg_navy"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_large"
            android:text="Start New Workout"
            android:textColor="@color/fitness_text_primary"
            android:textSize="@dimen/text_size_h1"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_small"
            android:layout_marginBottom="@dimen/spacing_xlarge"
            android:text="Log your exercise details below"
            android:textColor="@color/fitness_text_secondary"
            android:textSize="@dimen/text_size_body" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_rounded_card"
            android:orientation="vertical"
            android:padding="@dimen/spacing_large"
            android:layout_marginBottom="@dimen/spacing_xlarge">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select Exercise"
                android:textColor="@color/fitness_text_secondary"
                android:textSize="@dimen/text_size_caption"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerWorkoutExercise"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/spacing_small"
                android:background="@drawable/bg_input_field"
                android:padding="@dimen/spacing_small" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_large"
                android:text="Weight"
                android:textColor="@color/fitness_text_secondary"
                android:textSize="@dimen/text_size_caption"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etWeight"
                style="@style/Widget.Fitness.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:hint="e.g., 185"
                android:inputType="numberDecimal" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_large"
                android:text="Reps"
                android:textColor="@color/fitness_text_secondary"
                android:textSize="@dimen/text_size_caption"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etReps"
                style="@style/Widget.Fitness.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:hint="e.g., 5"
                android:inputType="number" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_large"
                android:text="Sets"
                android:textColor="@color/fitness_text_secondary"
                android:textSize="@dimen/text_size_caption"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etSets"
                style="@style/Widget.Fitness.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:hint="e.g., 3"
                android:inputType="number" />

        </LinearLayout>

        <Button
            android:id="@+id/btnSaveWorkout"
            style="@style/Widget.Fitness.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Workout" />

    </LinearLayout>
</ScrollView>