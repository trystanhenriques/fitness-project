<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitness_bg_navy"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <TextView
            style="@style/TextAppearanceFitnessScreenTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_large"
            android:text="Start New Workout" />

        <TextView
            style="@style/TextAppearanceFitnessScreenSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_small"
            android:layout_marginBottom="@dimen/spacing_xlarge"
            android:text="Log your exercise details below" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_rounded_card"
            android:orientation="vertical"
            android:padding="@dimen/spacing_large"
            android:layout_marginBottom="@dimen/spacing_xlarge">

            <TextView
                style="@style/TextAppearanceFitnessSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select Exercise" />

            <Spinner
                android:id="@+id/spinnerWorkoutExercise"
                style="@style/WidgetFitnessSpinner"
                android:layout_width="match_parent"
                android:layout_marginTop="@dimen/spacing_small"
                android:layout_height="wrap_content" />

            <TextView
                style="@style/TextAppearanceFitnessSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_large"
                android:text="Weight" />

            <EditText
                android:id="@+id/etWeight"
                style="@style/Widget.Fitness.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:hint="e.g., 185"
                android:inputType="numberDecimal" />

            <TextView
                style="@style/TextAppearanceFitnessSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_large"
                android:text="Reps" />

            <EditText
                android:id="@+id/etReps"
                style="@style/Widget.Fitness.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:hint="e.g., 5"
                android:inputType="number" />

            <TextView
                style="@style/TextAppearanceFitnessSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_large"
                android:text="Sets" />

            <EditText
                android:id="@+id/etSets"
                style="@style/Widget.Fitness.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:hint="e.g., 3"
                android:inputType="number" />

        </LinearLayout>

        <Button
            android:id="@+id/btnSaveWorkout"
            style="@style/Widget.Fitness.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Workout" />

    </LinearLayout>
</ScrollView>
